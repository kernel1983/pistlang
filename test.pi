l = [list (1, 2, 4)]
s = [set (1, 2, 2)]
t = (1, 2)
d = {1: 2, 3: 4}


fn square [x]
    return [* x x]

print
    [square 10]

print
    [list [map [fn [x] * x x] l]]

print [list [map [fn [x] * x x] l]]

# filter with lambda
print [list [filter [fn [x] [> x 2]] l]]

print
    [list [filter [fn [x] [== [% x 2] 0]] [range 1 10]]]

print
    list
        [filter [fn [x] [== [% x 2] 0]] [range 1 10]]

# filter then map
print
    [list [map [fn [x] * x 10] [filter [fn [x] [> x 2]] l]]]

# inline filter on range
print [list [filter [fn [x] [> x 5]] [range 1 10]]]

# nested block call: print(list(filter(...)))
print
    list
        [filter [fn [x] [== [% x 2] 0]] [range 1 10]]

